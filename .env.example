# ──────────────────────────────────────────────────────────────────────────────
# EspritSphere – Firebase environment configuration
# ──────────────────────────────────────────────────────────────────────────────
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below from your Firebase project console
#      (https://console.firebase.google.com → Project Settings → Your apps)
#   3. Build / run with:
#        flutter run  --dart-define-from-file=.env
#        flutter build apk --dart-define-from-file=.env
#   4. NEVER commit the .env file – it is listed in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Shared across platforms ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Web ───────────────────────────────────────────────────────────────────────
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_WEB_APP_ID=1:your-sender-id:web:your-web-app-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Android ───────────────────────────────────────────────────────────────────
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=1:your-sender-id:android:your-android-app-id

# ── iOS ───────────────────────────────────────────────────────────────────────
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=1:your-sender-id:ios:your-ios-app-id
FIREBASE_IOS_BUNDLE_ID=com.example.applicationuni
